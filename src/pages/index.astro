---
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/eb-garamond/500.css';
import '@fontsource/eb-garamond/600.css';
import '../styles/global.css';
import Wordmark from '../components/Wordmark.astro';
import LabCard from '../components/LabCard.astro';
import HomeRow from '../components/HomeRow.astro';
---

<html lang="ru">
  <head>
    <!-- Primary -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>Дармен Жолтай — darmen.best</title>
    <meta name="description" content="Строю цифровые системы для государства, промышленности и школ Казахстана. Product & Transformation Leader. 10+ запущенных IT-продуктов, команды до 70 человек." />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="darmen.best" />
    <meta property="og:url" content="https://darmen.best/" />
    <meta property="og:title" content="Дармен Жолтай — darmen.best" />
    <meta property="og:description" content="Строю цифровые системы для государства, промышленности и школ Казахстана. Product & Transformation Leader." />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:image" content="https://darmen.best/og.png" />
    <meta property="og:image:secure_url" content="https://darmen.best/og.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Дармен Жолтай · Product & Transformation Leader · darmen.best" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://darmen.best/" />
    <meta name="twitter:title" content="Дармен Жолтай — darmen.best" />
    <meta name="twitter:description" content="Строю цифровые системы для государства, промышленности и школ Казахстана." />
    <meta name="twitter:image" content="https://darmen.best/og.png" />
    <meta name="twitter:image:alt" content="Дармен Жолтай · Product & Transformation Leader · darmen.best" />

    <!-- Canonical -->
    <link rel="canonical" href="https://darmen.best/" />
  </head>
  <body>
    <article>
      <header class="logo-row">
        <Wordmark />
      </header>

      <h1>
        Строю цифровые системы<br />
        для государства,<br />
        промышленности и школ Казахстана.
      </h1>

      <p class="subtitle">
        10+ продуктов за карьеру. Три компании сейчас. B2G ERP в семи областях
        Казахстана, команды до 70 человек на пике. База в Астане.
      </p>

      <div class="contact-row">
        <a href="mailto:darmen.joltai@gmail.com">darmen.joltai@gmail.com</a>
      </div>

      <section class="lab-section">
        <div class="section-tag">lab — интерактивные разборы</div>
        <LabCard />
        <div class="archive-link">
          <a href="/lab">архив /lab&nbsp;→</a>
        </div>
      </section>

      <section class="building-section">
        <div class="section-tag">что строю сейчас</div>
        <div class="rows">
          <HomeRow
            kicker="2025 → "
            title="emissions.kz"
            body="Платформа экологического учёта и отчётности для промышленности. ERG — первый клиент, 17 объектов, цель 2026 — около ста."
            href="https://emissions.kz"
          />
          <HomeRow
            kicker="2026 → "
            title="Qazyna AI"
            body="Суверенная AI-first платформа учёта для госсектора. Альтернатива 1С и Парусу."
            meta="пилот в 2027"
            href="#"
          />
          <HomeRow
            kicker="2026 → "
            title="QVision"
            body="Образовательная экосистема: eOqulyq на E-Ink, школьный дизайн-код «Адал Азамат». Утверждён на уровне АП и МОН."
            meta="~100 школ"
            href="#"
          />
        </div>
      </section>

      <footer class="page-footer">
        <div class="footer-links">
          <a href="https://linkedin.com/in/darmen-joltai/">LinkedIn&nbsp;↗</a>
          <span class="copy">© 2026</span>
        </div>
        <p class="ps">
          P.S. Ануар и Аяна уже забрали свои .best, а .bestest не существует.
          Пришлось согласиться на darmen.best.
        </p>
      </footer>
    </article>

    <style>
      article {
        max-width: 880px;
        margin: 0 auto;
        padding: 64px 24px 80px;
        box-sizing: border-box;
      }
      .logo-row { margin-bottom: 96px; }

      h1 {
        /* H1 anchor — 36-52px range matches HomeEditorial.jsx mockup;
         * --t-hero (up to 64px) stays for hero numbers in labs. */
        font-size: clamp(36px, 4vw, 52px);
        font-weight: var(--w-medium);
        letter-spacing: var(--track-hero);
        line-height: 1.08;
        max-width: 720px;
        margin: 0;
      }

      .subtitle {
        margin-top: 32px;
        font-size: var(--t-lead);
        line-height: 1.5;
        color: var(--ink-muted);
        max-width: 620px;
      }

      .contact-row {
        margin-top: 28px;
        display: flex;
        gap: 24px;
        font-size: 15px;
        flex-wrap: wrap;
      }

      .lab-section,
      .building-section {
        margin-top: 96px;
      }

      .section-tag {
        font-size: 11px;
        letter-spacing: 0.18em;
        color: var(--ink-faint);
        text-transform: lowercase;
        margin-bottom: 16px;
      }

      .archive-link {
        margin-top: 16px;
        font-size: 13px;
        color: var(--ink-faint);
      }
      .archive-link a {
        color: inherit;
      }

      .rows {
        border-top: 0.5px solid var(--ink-line);
      }

      .page-footer {
        margin-top: 96px;
        padding-top: 24px;
        border-top: 0.5px solid var(--ink-line);
        display: flex;
        flex-direction: column;
        gap: 24px;
      }
      .footer-links {
        display: flex;
        gap: 24px;
        font-size: 14px;
        color: var(--ink-muted);
        flex-wrap: wrap;
      }
      .footer-links .copy {
        color: var(--ink-faint);
        border-bottom: none;
      }

      .ps {
        font-size: 13px;
        line-height: 1.55;
        color: var(--ink-faint);
        font-style: italic;
        max-width: 540px;
        margin: 0;
      }

      @media (min-width: 768px) {
        article { padding: 64px 64px 80px; }
      }
      @media (min-width: 1280px) {
        article { padding: 64px 96px 80px; }
      }
    </style>
  </body>
</html>
