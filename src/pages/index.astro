---
import '@fontsource/inter/400.css';
import '@fontsource/inter/700.css';
import '../styles/global.css';
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Darmen — Product & Transformation Leader</title>
  </head>
  <body class="bg-white font-sans">
    <section class="min-h-screen flex items-center justify-center px-6">
      <div class="max-w-[720px] w-full">
        <h1 class="text-[40px] md:text-[64px] font-bold tracking-tight leading-tight text-[#1F2937]">
          Строю цифровые системы для государства, промышленности и школ Казахстана.
        </h1>
        <p class="mt-8 text-[18px] text-[#4B5563]">
          Product & Transformation Leader. 10+ запущенных IT-продуктов. Команды до 70 человек.
        </p>
        <a
          href="mailto:darmen.joltai@gmail.com"
          class="mt-10 inline-block text-[16px] underline text-[#1F2937]"
        >
          Написать
        </a>
      </div>
    </section>
  </body>
</html>
