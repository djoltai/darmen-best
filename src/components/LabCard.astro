---
// Preview of the lab's post-toss trajectory chart: 11 possible paths (gray
// cloud) + 1 active path with segments coloured by zone (midpoint ≥ $1 →
// teal profit, < $1 → coral loss), mirroring drawTrajectoryAllIn in
// scripts/lab/frm-vol-drag/charts.ts. Same coin: ×1.5 / ×0.6 at p=0.5.
// All seeded — no Math.random, byte-stable across builds.

const N = 100;
const W = 320;
const H = 200;
const PAD_L = 28;
const PAD_R = 8;
const PAD_TB = 12;

// Y range: log10 [-4, +2] → $0.0001 .. $100. Six decades is plenty for
// the all-in lognormal cloud without dead margin on a small card.
const yMax = 2;
const yMin = -4;

const rand = (s: number) => {
  const x = Math.sin(s * 9301 + 49297) * 233280;
  return x - Math.floor(x);
};

const tx = (t: number) => PAD_L + (t / N) * (W - PAD_L - PAD_R);
const ty = (y: number) => {
  const ly = Math.log10(Math.max(0.0001, y));
  const clamped = Math.max(yMin, Math.min(yMax, ly));
  return PAD_TB + (1 - (clamped - yMin) / (yMax - yMin)) * (H - 2 * PAD_TB);
};

// One all-in coin-toss trajectory: cap *= 1.5 on heads (rand<0.5), 0.6 otherwise.
function genTraj(seed: number): number[] {
  const traj = [1];
  let cap = 1;
  for (let t = 1; t <= N; t++) {
    const r = rand(seed * 1000 + t);
    cap *= r < 0.5 ? 1.5 : 0.6;
    traj.push(cap);
  }
  return traj;
}

const bgSeeds = [100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110];
const bgTrajs = bgSeeds.map(genTraj);

const activeSeed = 173;
const activeTraj = genTraj(activeSeed);
const activeFinal = activeTraj[N];

const baselineY = ty(1).toFixed(1);

const toPath = (traj: number[]) =>
  traj
    .map((v, j) => `${j === 0 ? 'M' : 'L'} ${tx(j).toFixed(1)} ${ty(v).toFixed(1)}`)
    .join(' ');

const bgPaths = bgTrajs.map(toPath);

// Active path split into per-step segments coloured by *zone*, not by step:
// segment midpoint ≥ $1 → teal (profit zone), < $1 → coral (loss zone).
// Same convention as the lab's drawTrajectoryAllIn (charts.ts:127-129).
interface Seg { d: string; isWin: boolean; }
const activeSegs: Seg[] = [];
for (let t = 1; t <= N; t++) {
  const v0 = activeTraj[t - 1], v1 = activeTraj[t];
  activeSegs.push({
    d: `M ${tx(t - 1).toFixed(1)} ${ty(v0).toFixed(1)} L ${tx(t).toFixed(1)} ${ty(v1).toFixed(1)}`,
    isWin: (v0 + v1) / 2 >= 1,
  });
}

const finalX = tx(N).toFixed(1);
const finalY = ty(activeFinal).toFixed(1);
const finalIsWin = activeFinal >= 1;
---

<a href="/lab/frm-var" class="lab-card">
  <div class="chart-wrap">
    <svg
      viewBox={`0 0 ${W} ${H}`}
      preserveAspectRatio="xMidYMid meet"
      class="chart"
      aria-hidden="true"
    >
      <line
        x1={PAD_L}
        x2={W - PAD_R}
        y1={baselineY}
        y2={baselineY}
        stroke="var(--ink-line)"
        stroke-width="0.5"
        stroke-dasharray="2 3"
      />
      {bgPaths.map(d => (
        <path
          d={d}
          fill="none"
          stroke="var(--ink)"
          stroke-opacity="0.10"
          stroke-width="0.6"
          stroke-linejoin="round"
          stroke-linecap="round"
        />
      ))}
      {activeSegs.map(({ d, isWin }) => (
        <path
          d={d}
          fill="none"
          stroke={isWin ? 'var(--teal)' : 'var(--coral)'}
          stroke-width="1.4"
          stroke-linejoin="round"
          stroke-linecap="round"
        />
      ))}
      <circle
        cx={finalX}
        cy={finalY}
        r="3"
        fill={finalIsWin ? 'var(--teal)' : 'var(--coral)'}
      />
      <text
        x={PAD_L - 6}
        y={Number(baselineY) + 3}
        text-anchor="end"
        class="chart-label"
      >$1</text>
    </svg>
  </div>

  <div class="copy">
    <div class="tag">FRM · май 2026</div>
    <h3 class="title">Volatility Drag</h3>
    <p class="body">
      Положительное матожидание. Сто бросков. Ноль на руках.
      Игра в монетку и доля Kelly через интерактивный симулятор.
    </p>
    <div class="cta">Читать&nbsp;→</div>
  </div>
</a>

<style>
  .lab-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    padding: 32px;
    background: var(--bg-elev);
    color: var(--ink);
    text-decoration: none;
    border-bottom: none;
    align-items: center;
    transition: background-color var(--t-fast);
  }
  .lab-card:hover {
    background: #ECE5C5;
    color: var(--ink);
    border-bottom-color: transparent;
  }
  .chart-wrap {
    aspect-ratio: 16 / 10;
    width: 100%;
  }
  .chart {
    width: 100%;
    height: 100%;
    display: block;
  }
  .chart-label {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--ink-faint);
  }
  .tag {
    font-size: var(--t-tag);
    letter-spacing: var(--track-tag);
    color: var(--ink-muted);
    text-transform: lowercase;
  }
  .title {
    margin-top: 12px;
    font-size: 28px;
    font-weight: var(--w-medium);
    letter-spacing: -0.025em;
    line-height: var(--lh-tight);
  }
  .body {
    margin-top: 16px;
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink-muted);
  }
  .cta {
    margin-top: 24px;
    font-size: 14px;
    color: var(--teal);
    font-weight: var(--w-medium);
  }

  @media (max-width: 640px) {
    .lab-card {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 24px;
    }
    .title { font-size: 24px; }
  }
</style>
