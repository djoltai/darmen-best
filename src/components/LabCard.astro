---
// SVG chart is deterministic by construction: Math.sin-based seed,
// no Math.random. Trajectories are computed at build time and emitted
// as static SVG path data, so the rendered chart is byte-stable across
// builds. Vitest snapshot test is deferred until the repo grows a test
// runner for another reason — see JOURNAL 2026-05-18.

const N = 60;
const W = 320;
const H = 200;
const PAD = 8;

const yMax = Math.log10(50);
const yMin = Math.log10(0.001);

const seeds: Array<[number, number]> = [
  [0, 0.51], [1, 0.49], [2, 0.50], [3, 0.48], [4, 0.52],
  [5, 0.55], [6, 0.46], [7, 0.50], [8, 0.53], [9, 0.45],
  [10, 0.62],
  [11, 0.47],
];

const rand = (s: number) => {
  const x = Math.sin(s * 9301 + 49297) * 233280;
  return x - Math.floor(x);
};

const tx = (x: number) => PAD + (x / N) * (W - 2 * PAD);
const ty = (y: number) => {
  const ly = Math.log10(Math.max(0.0005, y));
  return PAD + (1 - (ly - yMin) / (yMax - yMin)) * (H - 2 * PAD);
};

interface Pt { x: number; y: number; }

const trajectories = seeds.map(([seed, bias]) => {
  let cap = 1;
  const pts: Pt[] = [{ x: 0, y: 1 }];
  for (let t = 1; t <= N; t++) {
    const r = rand(seed * 100 + t);
    cap *= r < bias ? 1.5 : 0.6;
    pts.push({ x: t, y: cap });
  }
  return pts;
});

const baselineY = ty(1).toFixed(1);

const paths = trajectories.map(pts => {
  const isUp = pts[pts.length - 1].y > 1.5;
  const d = pts
    .map((p, j) => `${j === 0 ? 'M' : 'L'} ${tx(p.x).toFixed(1)} ${ty(p.y).toFixed(1)}`)
    .join(' ');
  return { d, isUp };
});
---

<a href="/lab/frm-var" class="lab-card">
  <div class="chart-wrap">
    <svg
      viewBox={`0 0 ${W} ${H}`}
      preserveAspectRatio="xMidYMid meet"
      class="chart"
      aria-hidden="true"
    >
      <line
        x1={PAD}
        x2={W - PAD}
        y1={baselineY}
        y2={baselineY}
        stroke="var(--ink-line)"
        stroke-width="0.5"
        stroke-dasharray="2 3"
      />
      {paths.map(({ d, isUp }) => (
        <path
          d={d}
          fill="none"
          stroke={isUp ? 'var(--teal)' : 'var(--ink)'}
          stroke-opacity={isUp ? 0.9 : 0.28}
          stroke-width={isUp ? 1.4 : 0.8}
          stroke-linejoin="round"
          stroke-linecap="round"
        />
      ))}
      <text
        x={W - PAD - 2}
        y={Number(baselineY) - 4}
        text-anchor="end"
        class="chart-label"
      >$1</text>
    </svg>
  </div>

  <div class="copy">
    <div class="tag">FRM · май 2026</div>
    <h3 class="title">Volatility Drag</h3>
    <p class="body">
      Положительное матожидание. Сто бросков. Ноль на руках.
      Игра в монетку и доля Kelly через интерактивный симулятор.
    </p>
    <div class="cta">Читать&nbsp;→</div>
  </div>
</a>

<style>
