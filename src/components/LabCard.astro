    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    padding: 32px;
    background: var(--bg-elev);
    color: var(--ink);
    text-decoration: none;
    border-bottom: none;
    align-items: center;
    transition: background-color var(--t-fast);
  }
  .lab-card:hover {
    background: #ECE5C5;
    color: var(--ink);
    border-bottom-color: transparent;
  }
  .chart-wrap {
    aspect-ratio: 16 / 10;
    width: 100%;
  }
  .chart {
    width: 100%;
    height: 100%;
    display: block;
  }
  .chart-label {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--ink-faint);
  }
  .tag {
    font-size: var(--t-tag);
    letter-spacing: var(--track-tag);
    color: var(--ink-muted);
    text-transform: lowercase;
  }
  .title {
    margin-top: 12px;
    font-size: 28px;
    font-weight: var(--w-medium);
    letter-spacing: -0.025em;
    line-height: var(--lh-tight);
  }
  .body {
    margin-top: 16px;
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink-muted);
  }
  .cta {
    margin-top: 24px;
    font-size: 14px;
    color: var(--teal);
    font-weight: var(--w-medium);
  }

  @media (max-width: 640px) {
    .lab-card {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 24px;
    }
    .title { font-size: 24px; }
  }
</style>
